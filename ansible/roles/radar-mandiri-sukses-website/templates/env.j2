#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT=production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL='https://radar-ms.com'
app.forceGlobalSecureRequests=true

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname=mysql
database.default.database="{{ vault_mysql_database }}"
database.default.username="{{ vault_mysql_user }}"
database.default.password="{{ vault_mysql_password }}"
database.default.DBDriver=MySQLi
database.default.DBPrefix=
database.default.port=3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------
encryption.key="{{ vault_ci4_encryption_key }}"
