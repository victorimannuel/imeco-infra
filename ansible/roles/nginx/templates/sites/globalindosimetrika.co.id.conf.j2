server {
    listen 80;
    server_name globalindosimetrika.co.id www.globalindosimetrika.co.id;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name globalindosimetrika.co.id www.globalindosimetrika.co.id;

    ssl_certificate     /etc/nginx/ssl/globalindosimetrika.co.id/origin.crt;
    ssl_certificate_key /etc/nginx/ssl/globalindosimetrika.co.id/origin.key;

    # SSL optimization
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    root /var/www/gs/public/dist;
    index index.html;

    # Disable caching temporarily to reflect updates immediately
    add_header Cache-Control "no-cache, no-store, must-revalidate" always;
    add_header Pragma "no-cache" always;
    add_header Expires "0" always;

    # Redirect root to default language subdirectory
    location = / {
        return 301 /en/;
    }

    location / {
        try_files $uri $uri/ @lang_redirect;
    }

    # Canonicalize non-language URLs to /en/*.
    # Existing files (assets, sitemap, robots, etc.) are served directly by try_files above.
    location @lang_redirect {
        return 301 /en$request_uri;
    }

    # Logging
    access_log /var/log/nginx/globalindo.access.log;
    error_log /var/log/nginx/globalindo.error.log;
}
