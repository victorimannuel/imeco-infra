networks:
  appnet:
    external: true

services:
  phpmyadmin:
    image: phpmyadmin/phpmyadmin:5.2.1
    container_name: phpmyadmin
    ports:
      - "8080:80"
    environment:
      PMA_HOST: mysql
      PMA_USER: root
      PMA_PASSWORD: "{{ vault_mysql_root_password }}"
    mem_limit: 64m
    restart: always
    networks:
      - appnet
